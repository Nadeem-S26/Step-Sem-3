@startuml Use Case Diagram - ATM System

actor Customer as c
actor "Bank Database" as db

rectangle "ATM System" {
    usecase "Withdraw Money" as UC1
    usecase "Check Balance" as UC2
    usecase "Deposit Money" as UC3
    usecase "Authenticate User" as UC4
}

' Relationships
c --> UC4
UC4 --> UC1 : <<include>>
UC4 --> UC2 : <<include>>
UC4 --> UC3 : <<include>>

c --> UC1
c --> UC2
c --> UC3

UC1 --> db : <<extend>>
UC2 --> db : <<extend>>
UC3 --> db : <<extend>>

@enduml
